GROQ_API_KEY=your_groq_key
#
# Local offline mode (Ollama + Gemma)
# - If GROQ_API_KEY is missing, the agent will use Ollama automatically.
OLLAMA_HOST=http://127.0.0.1:11434
LOCAL_LLM_MODEL=gemma4
#
# STT selection:
# - If unset: uses Groq when GROQ_API_KEY exists, otherwise local Whisper.
# - Set explicitly to force behavior.
STT_PROVIDER=local
# Local Whisper (faster-whisper) model (examples: tiny.en, base.en, small.en, medium.en)
LOCAL_STT_MODEL=small.en
# faster-whisper runtime knobs
LOCAL_STT_DEVICE=auto
LOCAL_STT_COMPUTE_TYPE=auto
TAVILY_API_KEY=your_tavily_key
GOOGLE_CLIENT_ID=your_google_id
GOOGLE_CLIENT_SECRET=your_google_secret
SPOTIFY_CLIENT_ID=your_spotify_id
SPOTIFY_CLIENT_SECRET=your_spotify_secret
NOTION_TOKEN=your_notion_token
GITHUB_TOKEN=your_github_token
OPENWEATHER_API_KEY=your_weather_key
GEMINI_API_KEY=your_gemini_key
MCP_SERVER_URL=http://localhost:8080
